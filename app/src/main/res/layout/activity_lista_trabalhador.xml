<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#2E003E"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Barra superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#A45EE5"
        android:padding="8dp"
        android:paddingTop="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TA NA MÃO"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Campo de busca -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="2">

        <ImageView
            android:id="@+id/imageViewPerfilUsuario"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:scaleType="centerCrop"
            android:src="@drawable/imagem_padrao"
            android:background="@drawable/background_perfil"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Foto do usuário"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edtPesquisaCidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_background"
                android:hint="Buscar Cidade"
                android:textColor="@android:color/black"
                android:textColorHint="@android:color/darker_gray"
                android:padding="8dp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtPesquisa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_background"
                android:hint="Buscar Trabalhador"
                android:textColor="@android:color/black"
                android:textColorHint="@android:color/darker_gray"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Categorias horizontais -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewCargos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:scrollbars="horizontal" />

    <!-- Lista de trabalhadores -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTrabalhadores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

</LinearLayout>